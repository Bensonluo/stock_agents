# Database
DATABASE_URL=postgresql://admin:your_password@localhost:5432/stockdb
REDIS_URL=redis://localhost:6379

# API Keys (if using paid services)
# TUSHARE_TOKEN=your_tushare_token
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key
# FINNHUB_API_KEY=your_finnhub_api_key
# Get free key from: https://finnhub.io/ (60 req/min free tier)

# LLM Configuration
# For GLM-4 models (Zhipu AI) - Recommended for Chinese users
ZHIPUAI_API_KEY=your_zhipuai_api_key
# Get your API key from: https://open.bigmodel.cn/

# Optional: OpenAI (fallback)
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key

# LLM Model Selection (GLM models)
# glm-4.7 - Most capable (recommended for analysis)
# glm-4.5-air - Fast and cost-effective
# glm-4.5 - Standard model
PRIMARY_LLM_MODEL=glm-4.7
SECONDARY_LLM_MODEL=glm-4.5-air
BATCH_LLM_MODEL=glm-4.5-air

# LLM Parameters
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# JWT Secret
JWT_SECRET=your_jwt_secret_change_this_in_production

# Application Settings
LOG_LEVEL=INFO
MAX_RETRIES=3
TIMEOUT_PER_AGENT=300
PARALLEL_EXECUTION=true

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# CORS
FRONTEND_URL=http://localhost:3000
